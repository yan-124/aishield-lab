# DashScope API Key — server-side only, NEVER use VITE_ prefix
# Get your API key from https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# Admin dashboard secret — set to a strong random string
ADMIN_SECRET=your_admin_secret_here

# JWT secret for auth tokens — set to a strong random string
JWT_SECRET=your_jwt_secret_here